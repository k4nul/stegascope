{
  "schema_version": "1.0.0",
  "project": "stegascope",
  "current_phase": "container-side-channels",
  "next_phase": "audio-lsb-analysis",
  "transition": {
    "intent": "Move from container-side-channels only after the first image-container analyzer package is implemented and tested, same-name payload downloads use deterministic payload IDs with current-result lookup, and the current frontend/Rust local-file boundary remains explicit.",
    "mode": "machine-gated-analyzer-expansion",
    "validation_command": "npm run build",
    "transition_validation_command": "npm run build",
    "decision_rule": "All required gates must pass their validation evidence or be explicitly waived before changing current_phase; machine-check status describes how a gate is validated, not a pass result."
  },
  "phase_model": [
    {
      "id": "container-side-channels",
      "purpose": "Implement the first image-container analyzer package for JPEG and PNG side-channel evidence, including current-result payload ID disambiguation for extracted downloads.",
      "allowed_work": [
        "JPEG segment analysis",
        "PNG deep container analysis",
        "Rust analyzer tests",
        "local file boundary evidence",
        "deterministic payload ID download disambiguation",
        "frontend build validation"
      ],
      "blocked_work": [
        "large unscoped analyzer catalog rewrites",
        "real evidence files",
        "product direction lock-in outside the selected analyzer package"
      ],
      "exit_criteria": [
        "JPEG segment analyzer exists",
        "PNG deep container scan exists",
        "Rust analyzer tests cover the package",
        "local file boundary evidence exists",
        "same-name payload ID download lookup exists",
        "frontend build passes"
      ]
    },
    {
      "id": "audio-lsb-analysis",
      "purpose": "Validate and formalize the existing WAV PCM LSB analyzer package after image-container analysis is stable.",
      "allowed_work": [
        "WAV PCM sample LSB analysis",
        "focused analyzer tests"
      ],
      "blocked_work": [
        "broad media pipeline rewrites before Rust-side ingestion is selected"
      ],
      "exit_criteria": [
        "WAV PCM LSB analyzer evidence is validated",
        "audio analyzer tests pass"
      ]
    },
    {
      "id": "rust-side-ingestion",
      "purpose": "Harden Rust-side local file ingestion and retire legacy byte-input compatibility after current path-based attach evidence is stable.",
      "allowed_work": [
        "IPC boundary hardening",
        "local file handling",
        "command-level validation",
        "legacy byte-input compatibility cleanup"
      ],
      "blocked_work": [
        "cloud upload or external service dependencies"
      ],
      "exit_criteria": [
        "path-based attach remains the frontend default",
        "legacy byte-input command is removed or explicitly retained for a documented compatibility caller",
        "command-level tests cover attach, analyze, and invalid-path behavior"
      ]
    },
    {
      "id": "release-readiness",
      "purpose": "Prepare the desktop app for a public-safe release handoff.",
      "allowed_work": [
        "documentation",
        "packaging checks",
        "security review"
      ],
      "blocked_work": [
        "new analyzer families without a selected phase"
      ],
      "exit_criteria": [
        "release checklist is complete",
        "local-only safety assumptions are documented"
      ]
    }
  ],
  "required_gates": [
    {
      "id": "frontend-build-passes",
      "status": "machine-check",
      "required_for_transition": true,
      "description": "The existing frontend build command must pass.",
      "evidence": [
        "npm run build"
      ]
    },
    {
