{
  "name": "stegascope",
  "private": true,
  "version": "0.1.0",
  "description": "Tauri desktop workspace for steganography-focused media analysis.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "validate:download-ipc": "node scripts/validate-download-ipc.mjs",
    "validate:phase-evidence": "node scripts/validate-phase-evidence.mjs",
    "validate:toolchain-readiness": "node scripts/validate-toolchain-readiness.mjs",
    "validate:static": "node --check scripts/validate-download-ipc.mjs && node --check scripts/validate-phase-evidence.mjs && node --check scripts/validate-toolchain-readiness.mjs && node scripts/validate-phase-evidence.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
